{
  "name": "scanlab",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "serve": "nodemon --inspect server.js",
    "lint": "eslint --fix api db util",
    "dev-db": "docker run --rm --name pg-scanlab -e POSTGRES_DB=scanlab -e POSTGRES_PASSWORD=e5832048e0 -d -p 5432:5432 -v scanlab_postgres:/var/lib/postgresql/data postgres:16",
    "cruise": "yarn install && yarn start",
    "up": "yarn upgrade-interactive --latest",
    "ship": "git checkout master && git pull && git push heroku master:main",
    "test": "jest",
    "migration-script:primary": "node ./db/scripts/migrations.js",
    "prisma-migrate-dev:primary": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma-migrate-dev:eu": "prisma migrate dev --schema=prisma/eu/schema.prisma",
    "prisma-migrate-dev": "yarn run prisma-migrate-dev:primary && yarn run prisma-migrate-dev:eu && yarn run migration-script:primary",
    "prisma-migrate-deploy:primary": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma-migrate-deploy:eu": "prisma migrate deploy --schema=prisma/eu/schema.prisma",
    "prisma-migrate-deploy": "yarn run prisma-migrate-deploy:primary && yarn run prisma-migrate-deploy:eu && yarn run migration-script:primary"
  },
  "description": "",
  "main": "index.js",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/cloudfront-signer": "^3.500.0",
    "@aws-sdk/lib-storage": "^3.500.0",
    "@aws-sdk/s3-presigned-post": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@google-cloud/translate": "^7.0.3",
    "@hapi/joi": "^17.1.1",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^7.15.0",
    "axios": "^1.1.3",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.1",
    "btoa": "^1.2.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv-defaults": "^5.0.2",
    "eslint-plugin-node": "^11.1.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-validation": "^4.1.0",
    "jwt-simple": "^0.5.6",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "moment": "^2.29.4",
    "nodemailer": "^6.8.0",
    "nodemailer-sendgrid-transport": "^0.2.0",
    "pg": "^8.8.0",
