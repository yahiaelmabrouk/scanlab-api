  defaultContrastAndSalineProtocol         Int                            @default(1)
  sliceExpansionBehavior                   Int                            @default(1)
  preferredAnswerCriteriaByStackQuestionId Json?
  preferredTimingMethod                    String?                        @db.VarChar(20)
