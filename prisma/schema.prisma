model ApiKey {
  id               Int                     @id @default(autoincrement())
  name             String                  @db.VarChar(255)
  keyPrefix        String                  @unique @db.VarChar(10)
  keyHash          String                  @db.VarChar(255)
  cohortId         Int
  isActive         Boolean                 @default(true)
  expiresAt        DateTime?               @db.Timestamptz(6)
  lastUsedAt       DateTime?               @db.Timestamptz(6)
  rateLimit        Int                     @default(1000) // Requests per hour
  rateLimitWindow  Int                     @default(3600) // Window in seconds (1 hour)
  createdAt        DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @db.Timestamptz(6)
  Cohort           Cohort                  @relation(fields: [cohortId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usage            ApiKeyUsage[]
  accessAttempts   EndpointAccessAttempt[]

  @@index([cohortId], map: "api_keys_cohort_id")
  @@index([keyPrefix], map: "api_keys_key_prefix")
  @@map("ApiKeys")
}

model ApiKeyUsage {
  id         Int       @id @default(autoincrement())
  apiKeyId   Int
  endpoint   String    @db.VarChar(500)
  method     String    @db.VarChar(10)
  statusCode Int
  timestamp  DateTime  @default(now()) @db.Timestamptz(6)
  ipAddress  String?   @db.VarChar(45)
  userAgent  String?   @db.Text
  apiKey     ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([apiKeyId], map: "api_key_usage_api_key_id")
  @@index([timestamp], map: "api_key_usage_timestamp")
  @@map("ApiKeyUsage")
}

model Endpoint {
  id                      Int                       @id @default(autoincrement())
  method                  String                    @db.VarChar(10)
  path                    String                    @db.VarChar(500)
  pathPattern             String                    @db.VarChar(500)
  name                    String                    @db.VarChar(255)
  description             String?                   @db.Text
  service                 String?                   @db.VarChar(100)
  version                 String                    @default("v1") @db.VarChar(20)
  requiresAuth            Boolean                   @default(true)
  isActive                Boolean                   @default(false)
  createdAt               DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                  @updatedAt @db.Timestamptz(6)
  cohortPermissions       CohortEndpointPermission[]
  accessAttempts          EndpointAccessAttempt[]

  @@unique([method, pathPattern, version])
  @@index([service], map: "endpoints_service")
  @@index([pathPattern], map: "endpoints_path_pattern")
  @@map("Endpoints")
}

model CohortEndpointPermission {
  id                 Int       @id @default(autoincrement())
  cohortId           Int
  endpointId         Int
  isAllowed          Boolean   @default(true)
  maxRequestsPerHour Int?
  description        String?   @db.Text
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6)
  cohort             Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  endpoint           Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cohortId, endpointId])
  @@index([cohortId], map: "cohort_endpoint_permissions_cohort_id")
  @@index([endpointId], map: "cohort_endpoint_permissions_endpoint_id")
  @@map("CohortEndpointPermissions")
}

model EndpointAccessAttempt {
  id              Int       @id @default(autoincrement())
  apiKeyId        Int?
  endpointId      Int?
  method          String    @db.VarChar(10)
  path            String    @db.VarChar(500)
  statusCode      Int
  isAllowed       Boolean
  denyReason      String?   @db.VarChar(255)
  timestamp       DateTime  @default(now()) @db.Timestamptz(6)
  ipAddress       String?   @db.VarChar(45)
  userAgent       String?   @db.Text
  requestDuration Int?
  apiKey          ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  endpoint        Endpoint? @relation(fields: [endpointId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([apiKeyId], map: "endpoint_access_attempts_api_key_id")
  @@index([endpointId], map: "endpoint_access_attempts_endpoint_id")
  @@index([timestamp], map: "endpoint_access_attempts_timestamp")
  @@index([statusCode, isAllowed], map: "endpoint_access_attempts_status")
  @@map("EndpointAccessAttempts")
}

