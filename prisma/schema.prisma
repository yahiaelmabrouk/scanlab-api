model InterventionRule {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain        String   @db.VarChar(16)
  skillId       String?  @db.VarChar(255)
  categoryId    Int?
  level         String?  @db.VarChar(16)
  metric        String?  @db.VarChar(32)
  aggregation   String?  @db.VarChar(32)
  scope         String?  @db.VarChar(16)
  fromValue     Decimal  @db.Decimal(10, 3)
  toValue       Decimal  @db.Decimal(10, 3)
  interventions Json
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt      @db.Timestamptz(6)
  createdBy     Int

  category Category? @relation(fields: [categoryId], references: [id])
  author   User      @relation(fields: [createdBy], references: [id])

  @@index([domain, skillId])
  @@index([domain, categoryId, level])
  @@index([domain, metric])
  @@map("InterventionRules")
}

