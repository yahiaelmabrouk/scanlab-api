generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_PRIMARY")
}

model ResourceCategory {
  id        Int        @id @default(autoincrement())
  createdAt DateTime?  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime?  @updatedAt @db.Timestamptz(6)
  name      String     @default("")
  resources Resource[]

  @@map("ResourceCategories")
}

model Resource {
  id               Int               @id @default(autoincrement())
  createdAt        DateTime?         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?         @updatedAt @db.Timestamptz(6)
  title            String
  description      String?           @default("")
  url              String?           @default("{}")
  path             String?           @default("{}")
  language         String            @default("en")
  categoryId       Int?
  resourceCategory ResourceCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  type             Int               @default(1)
  sortOrder        Int               @default(0)

  @@map("Resources")
}

model Language {
  id        Int       @id @default(autoincrement())
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @db.Timestamptz(6)
  code      String
  name      String?   @default("")
  content   Json      @default("{}")
  flag      String?   @default("")

  @@map("Languages")
}

model PatientPhysioCardiacLevel {
  id                    Int            @id @default(autoincrement())
  createdAt             DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime?      @updatedAt @db.Timestamptz(6)
  levelType             Int            @default(1)
  cardiacCycleDuration  Int            @default(300)
  cardiacCycleDeviation Int            @default(0)
  badBeats              Int            @default(1)
  badBeatsDuration      Json?          @default("{\"isRange\":false,\"min\":400,\"max\":400}")
  continuousECGData     Json?          @default("{\"data\":[],\"waveWidth\":0,\"distanceFromTwoWave\":0,\"centerRToCenterT\":0,\"startPToCenterR\":0,\"centerTToEnd\":0, \"distanceFromSToT\":0, \"distanceFromPToQ\":0}")
  patientPhysio         PatientPhysio? @relation(fields: [patientPhysioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patientPhysioId       Int?

  @@map("PatientPhysioCardiacLevels")
}

model PatientPhysio {
  id                       Int                         @id @default(autoincrement())
  createdAt                DateTime?                   @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime?                   @updatedAt @db.Timestamptz(6)
  name                     String
  strokeVol                Int                         @default(40)
  age                      Int                         @default(20)
  respiratoryCycleDuration Int                         @default(500)
  breathHoldDuration       Int                         @default(0)
  unit                     Int                         @default(1)
  difficulty               Int                         @default(1)
  cardiacLevels            PatientPhysioCardiacLevel[]
  preparedExams            PreparedExam[]

  @@map("PatientPhysios")
}

model ContrastRangePreset {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime? @updatedAt @db.Timestamptz(6)
  weighting  String?
  magPrep    String?
  sequence   String?
  bodyPart   BodyPart? @relation(fields: [bodyPartId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bodyPartId Int?
  ranges     Json

  @@index([bodyPartId], map: "contrast_range_preset_body_part")
  @@map("ContrastRangePresets")
}

model InjectionAttribute {
  id                  Int       @id @default(autoincrement())
  bodyPartId          Int?
  createdAt           DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime? @updatedAt @db.Timestamptz(6)
  contrastMinDose     Float?    @default(0)
  contrastMaxDose     Float?    @default(0)
  contrastMinFlowRate Float?    @default(0)
  contrastMaxFlowRate Float?    @default(0)
  salineMinDose       Float?    @default(0)
  salineMaxDose       Float?    @default(0)
  salineMinFlowRate   Float?    @default(0)
  salineMaxFlowRate   Float?    @default(0)
  minTime             Int?      @default(0)
  posts               Json      @default("[]") @db.Json
  maxTime             Int?      @default(0)
  bodyPart            BodyPart? @relation(fields: [bodyPartId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bodyPartId], map: "injection_attribute_body_part")
  @@map("InjectionAttributes")
}

model Model {
  id             Int       @id @default(autoincrement())
  name           String
  fileName       String
  gender         String    @default("female")
  age            Int?      @default(0)
  to             Int?      @default(100)
  weightImperial Float?    @default(0) @db.DoublePrecision
  weightMetric   Float?    @default(0) @db.DoublePrecision
  heightImperial Float?    @default(0) @db.DoublePrecision
  heightMetric   Float?    @default(0) @db.DoublePrecision
  heightInches   Float?    @default(0) @db.DoublePrecision
  attributes     Json      @default("[]") @db.Json
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime? @updatedAt @db.Timestamptz(6)
  bodyBoxes      BodyBox[]

  @@map("Models")
}

model BodyBox {
  id                        Int             @id @default(autoincrement())
  x                         Float           @db.DoublePrecision
  y                         Float           @db.DoublePrecision
  z                         Float           @db.DoublePrecision
  width                     Float           @db.DoublePrecision
  height                    Float           @default(20) @db.DoublePrecision
  length                    Float           @db.DoublePrecision
  landmarkTolerance         Float           @default(1) @db.DoublePrecision
  landmarkToleranceBottom   Float           @default(1) @db.DoublePrecision
  landmarkToleranceVertical Float           @default(1) @db.DoublePrecision
  createdAt                 DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime        @updatedAt @db.Timestamptz(6)
  bodyBoxDirection          Int             @default(1)
  mriUpDownPositionY        Float           @default(0) @db.DoublePrecision
  bodyPartId                Int
  patientPositionId         Int
  modelId                   Int?
  patientPosition           PatientPosition @relation(fields: [patientPositionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  model                     Model?          @relation(fields: [modelId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("BodyBoxes")
}

model PatientPosition {
  id                 Int                 @id @default(autoincrement())
  value              Json                @db.Json
  isShowHeadHolder   Boolean             @default(false)
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(6)
  bodyPartId         Int
  BodyPart           BodyPart?           @relation(fields: [bodyPartId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  positionSetId      Int?
  patientPositionSet PatientPositionSet? @relation(fields: [positionSetId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bodyBoxes          BodyBox[]

  @@index([bodyPartId], map: "patient_position_body_part_id")
  @@map("PatientPositions")
}

model PatientPositionSet {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(255)
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)
  patientPositions PatientPosition[]
  stackQuestions   StackQuestion[]
  bodyPartId       Int?
  bodyPart         BodyPart?         @relation(fields: [bodyPartId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("PatientPositionSets")
}

model BodyPart {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @db.VarChar(255)
  createdAt               DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @db.Timestamptz(6)
  withOut                 Boolean                  @default(false)
  withOnly                Boolean                  @default(false)
  withOutWith             Boolean                  @default(false)
  baseId                  Int?
  regionId                Int
  contrastTypes           Json                     @default("{}") @db.Json
  Base                    BodyPart?                @relation("BodyPartAndBases", fields: [baseId], references: [id])
  Extends                 BodyPart[]               @relation("BodyPartAndBases")
  Region                  Region                   @relation(fields: [regionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  DigitalLocalizers       DigitalLocalizer[]
  DicomFileSets           DicomFileSet[]
  MultipleChoiceQuestions MultipleChoiceQuestion[]
  QuestionSets            QuestionSet[]
  PatientPositions        PatientPosition[]
  injectionAttributes     InjectionAttribute[]
  ContrastRangePresets    ContrastRangePreset[]
  PatientPositionSets     PatientPositionSet[]
  QuestionProbes          QuestionProbe[]

  @@index([regionId], map: "body_parts_region_id")
  @@map("BodyParts")
}

model Category {
  id                      Int                      @id @default(autoincrement())
  name                    String?                  @db.VarChar(255)
  createdAt               DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @db.Timestamptz(6)
  MultipleChoiceQuestions MultipleChoiceQuestion[]
  InterventionRules       InterventionRule[]

  @@map("Categories")
}

model CohortManager {
  id        Int      @id @default(autoincrement())
  cohortId  Int
  userId    Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  Cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cohortId, userId])
  @@map("CohortManagers")
}

model CohortPreparedExam {
  id        Int      @id @default(autoincrement())
  cohortId  Int
  examId    Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  Cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("CohortPreparedExams")
}

model CohortStudent {
  id                  Int               @id @default(autoincrement())
  userId              Int?
  cohortId            Int
  registrationCodeId  Int?
  createdAt           DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @db.Timestamptz(6)
  settingsFromManager Json              @default("{}") @db.Json
  Cohort              Cohort            @relation(fields: [cohortId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  RegistrationCode    RegistrationCode? @relation(fields: [registrationCodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User                User?             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cohortId], map: "cohort_students_cohort_id")
  @@index([userId], map: "cohort_students_user_id")
  @@index([cohortId, userId], map: "cohort_students_cohort_id_user_id")
  @@map("CohortStudents")
}

model Cohort {
  id                              Int                  @id @default(autoincrement())
  name                            String               @db.VarChar(255)
  createdAt                       DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt                       DateTime             @updatedAt @db.Timestamptz(6)
  availableRegistrationCodesCount Int                  @default(0)
  studentsCount                   Int                  @default(0)
  settings                        Json                 @default("{}")
  adminSettings                   Json                 @default("{ \"isActive\": true, \"isPlaygroundEnabled\": false, \"isRandomModeEnabled\": false, \"isChallengeModeEnabled\": false, \"isTestByRegionEnabled\": true, \"amountOfCriticalThinkingQuestionsPerTestRun\": 4 }")
  expirationLength                String?              @default("365") @db.VarChar(255)
  area                            String?              @default("us_east")
  CohortManagers                  CohortManager[]
  CohortStudents                  CohortStudent[]
  RegistrationCodes               RegistrationCode[]
  CohortPreparedExams             CohortPreparedExam[]
  ApiKeys                         ApiKey[]
  endpointPermissions             CohortEndpointPermission[]

  @@map("Cohorts")
}

model CohortAverageCache {
  id                  Int       @id @default(autoincrement())
  cohortId            Int       @unique
  angleAverage          Float?
  wastedSlicesAverage   Float?
  wastedCoverageAverage Float?
  lastUpdatedAt         DateTime  @default(now())
  lastUsed              DateTime?

  @@map("CohortAverageCache")
}

model UserStatsCache {
  id                   Int       @id @default(autoincrement())
  userId               Int
  cacheType            String
  includeChallengeMode Boolean   @default(false)

  // this will hold the full precomputed payload for that user
  // (array of rows for /statistics or /statistics/tests/whom)
  data                 Json      @db.JsonB

  lastUpdatedAt        DateTime  @default(now())
  lastUsed             DateTime?

  @@unique([userId, cacheType, includeChallengeMode])
  @@index([lastUsed])

  @@map("UserStatsCaches")
}

model DicomFileSet {
  id                        Int                        @id @default(autoincrement())
  name                      String?                    @db.VarChar(255)
  createdAt                 DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @db.Timestamptz(6)
  regionId                  Int?
  flipAxial                 Boolean?                   @default(false)
  flipCoronal               Boolean?                   @default(false)
  flipSagittal              Boolean?                   @default(false)
  isUltraLab                Boolean?                   @default(false)
  type                      String?                    @db.VarChar(255)
  linkedDicoms              Json?                      @db.Json
  userViewOnlyAllowed       Boolean                    @default(false)
  bodyPartId                Int?
  localizerBoundingBoxes    Json?                      @default("[]")
  scanBoundingBoxes         Json?                      @default("[]")
  dicomCategory             Int                        @default(0)
  localizerNames            Json?                      @default("{}")
  availablePositions        Json?                      
  BodyPart                  BodyPart?                  @relation(fields: [bodyPartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Region                    Region?                    @relation(fields: [regionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  JoinUploadToDicomFileSets JoinUploadToDicomFileSet[]
  QuestionMediaDicoms       QuestionMediaDicom[]
  QuestionSets              QuestionSet[]

  @@map("DicomFileSets")
}

model JoinUploadToDicomFileSet {
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  uploadId       Int
  dicomFileSetId Int
  DicomFileSet   DicomFileSet @relation(fields: [dicomFileSetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Upload         Upload       @relation(fields: [uploadId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([uploadId, dicomFileSetId])
}

model MultipleChoiceQuestionResult {
  id                       Int                    @id @default(autoincrement())
  answer                   String?
  createdAt                DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime               @updatedAt @db.Timestamptz(6)
  userId                   Int
  multipleChoiceQuestionId Int
  testRunId                Int?
  score                    Decimal                @db.Decimal(5, 2)
  MultipleChoiceQuestion   MultipleChoiceQuestion @relation(fields: [multipleChoiceQuestionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  TestRun                  TestRun?               @relation(fields: [testRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User                     User                   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("MultipleChoiceQuestionResults")
}

model MultipleChoiceQuestion {
  id                            Int                            @id @default(autoincrement())
  questionText                  String?
  choices                       Json?                          @db.Json
  answerExplanation             String?
  createdAt                     DateTime                       @default(now()) @db.Timestamptz(6)
  updatedAt                     DateTime                       @updatedAt @db.Timestamptz(6)
  categoryId                    Int
  bodyPartId                    Int?
  difficulty                    Int?
  type                          String                         @default("MC") @db.VarChar(255)
  range                         Json?                          @db.Json
  onlyForPreparedExams          Boolean                        @default(false)
  globalQuestion                Boolean                        @default(false)
  secondsToAnswer               Int                            @default(45)
  screeningForm                 Json                           @default("{}")
  hideQuestion                  Boolean                        @default(false)
  isGeneralQuestion             Boolean?                       @default(false)
  keepOrder                     Boolean?                       @default(false)
  isBetaQuestion                Boolean                        @default(false)
  betaQuestionAttempts          Int                            @default(0)
  BodyPart                      BodyPart?                      @relation(fields: [bodyPartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Category                      Category                       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  MultipleChoiceQuestionResults MultipleChoiceQuestionResult[]
  QuestionMedias                QuestionMedia[]
  QuestionMiscDocuments         QuestionMiscDocument[]

  @@map("MultipleChoiceQuestions")
}

model PreparedExam {
  id                        Int            @id @default(autoincrement())
  questions                 Json           @default("{ \"preTestQuestions\": [], \"questionSetId\": null, \"postTestQuestions\": [] }") @db.Json
  title                     String         @default("New Prepared Exam")
  published                 Boolean        @default(false)
  createdAt                 DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime       @updatedAt @db.Timestamptz(6)
  isSkill                   Boolean        @default(true)
  isHiring                  Boolean        @default(false)
  isDynamic                 Boolean        @default(false)
  regionId                  Int?
  bodyPartId                Int?
  postQuestionCount         Int?
  postQuestionBodyPartCount Int?
  postQuestionGroupId       Int?
  preQuestionGroupId        Int?
  patientPhysioId           Int?
  postQuestionGroup         QuestionGroup? @relation("PostQuestionGroup", fields: [postQuestionGroupId], references: [id])
  preQuestionGroup          QuestionGroup? @relation("PreQuestionGroup", fields: [preQuestionGroupId], references: [id])
  patientPhysio             PatientPhysio? @relation(fields: [patientPhysioId], references: [id])

  @@map("PreparedExams")
}

model QuestionMedia {
  id                       Int                     @id @default(autoincrement())
  multipleChoiceQuestionId Int?
  createdAt                DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                @updatedAt @db.Timestamptz(6)
  MultipleChoiceQuestion   MultipleChoiceQuestion? @relation(fields: [multipleChoiceQuestionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  QuestionMediaDicoms      QuestionMediaDicom[]
  QuestionMediaUploads     QuestionMediaUpload[]
}

model QuestionMediaDicom {
  id              Int            @id @default(autoincrement())
  questionMediaId Int?
  dicomFileSetId  Int?
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6)
  DicomFileSet    DicomFileSet?  @relation(fields: [dicomFileSetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  QuestionMedia   QuestionMedia? @relation(fields: [questionMediaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("QuestionMediaDicoms")
}

model QuestionMediaUpload {
  id              Int            @id @default(autoincrement())
  alt             String?        @db.VarChar(255)
  pathKey         String?        @db.VarChar(255)
  filename        String?        @db.VarChar(255)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6)
  type            String?        @db.VarChar(255)
  dimensions      Json?          @db.Json
  questionMediaId Int?
  QuestionMedia   QuestionMedia? @relation(fields: [questionMediaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("QuestionMediaUploads")
}

model QuestionMiscDocument {
  id                       Int                     @id @default(autoincrement())
  alt                      String?                 @db.VarChar(255)
  pathKey                  String?                 @db.VarChar(255)
  filename                 String?                 @db.VarChar(255)
  type                     String?                 @db.VarChar(255)
  multipleChoiceQuestionId Int?
  createdAt                DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                @updatedAt @db.Timestamptz(6)
  MultipleChoiceQuestion   MultipleChoiceQuestion? @relation(fields: [multipleChoiceQuestionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("QuestionMiscDocuments")
}

model QuestionSetResult {
  id                   Int                   @id @default(autoincrement())
  score                Decimal?              @db.Decimal(5, 2)
  sliceQuantScore      Decimal?              @db.Decimal(5, 2)
  overallSkillScores   Json?                 @db.Json
  createdAt            DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @db.Timestamptz(6)
  isViewedAdminComment Boolean?              @default(true)
  isViewedUserReply    Boolean?              @default(true)
  isViewedAdminReply   Boolean?              @default(true)
  userId               Int
  questionSetId        Int?
  testRunId            Int?
  isChallengeMode      Boolean?
  QuestionSet          QuestionSet?          @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  TestRun              TestRun?              @relation(fields: [testRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User                 User                  @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  StackQuestionResults StackQuestionResult[]

  @@index([userId], map: "question_set_results_user_id")
  @@index([testRunId], map: "question_set_results_test_run_id")
  @@index([questionSetId], map: "question_set_results_question_set_id")
  @@map("QuestionSetResults")
}

model QuestionSet {
  id                 Int                 @id @default(autoincrement())
  name               String?             @db.VarChar(255)
  dicomFileSet       Int
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(6)
  bodyPartId         Int?
  isAvailable        Boolean             @default(true)
  isPreparedExamOnly Boolean             @default(false)
  isUltraLab         Boolean             @default(false)
  rarity             String?             @default("common") @db.VarChar(255)
  ageFrom            Int?
  ageTo              Int?
  gender             String?
  BodyPart           BodyPart?           @relation(fields: [bodyPartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  DicomFileSets      DicomFileSet        @relation(fields: [dicomFileSet], references: [id], onDelete: NoAction, onUpdate: NoAction)
  QuestionSetResults QuestionSetResult[]
  StackQuestions     StackQuestion[]

  @@index([bodyPartId], map: "question_sets_body_part_id")
  @@map("QuestionSets")
}

model QuestionProbe {
  id                           Int                 @id @default(autoincrement())
  bodyPartId                   Int                 @default(1)
  scanDirection                Int                 @default(1)
  visibleProbes                Json                @default("[]")
  createdAt                    DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt                    DateTime            @updatedAt @db.Timestamptz(6)
  BodyPart                     BodyPart?           @relation(fields: [bodyPartId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("QuestionProbes")
}

model Region {
  id              Int            @id @default(autoincrement())
  name            String         @db.VarChar(255)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6)
  anatomicalOrder Int?           @unique
  BodyParts       BodyPart[]
  DicomFileSets   DicomFileSet[]

  @@map("Regions")
}

model RegistrationCode {
  id              Int                     @id @default(autoincrement())
  code            String                  @unique @db.VarChar(255)
  used            Boolean?                @default(false)
  cohortId        Int
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(6)
  notes           String?
  expirationDate  DateTime?               @db.Timestamptz(6)
  status          RegistrationCodesStatus @default(active)
  activationDate  DateTime?               @db.Timestamptz(6)
  numOfDaysActive Int                     @default(365)
  userId          Int?
  Cohort          Cohort                  @relation(fields: [cohortId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  CohortStudents  CohortStudent[]
  User            User?                   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("RegistrationCodes")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  userId    Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([name, userId], map: "roles_name_user_id")
  @@map("Roles")
}

model StackQuestionResult {
  id                         Int                          @id @default(autoincrement())
  score                      Decimal?                     @db.Decimal(5, 2)
  attemptedAnswerIdentifier  String?                      @db.VarChar(255)
  createdAt                  DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime                     @updatedAt @db.Timestamptz(6)
  answer                     Json?                        @db.Json
  comment                    String?                      @default("")
  commentCreatedAt           DateTime?                    @default(now()) @db.Timestamptz(6)
  commentedUserId            Int?
  commentSeenAt              DateTime?                    @default(now()) @db.Timestamptz(6)
  isViewedAdminComment       Boolean?                     @default(true)
